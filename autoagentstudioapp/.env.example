# Google Generative AI API Key
GEMINI_API_KEY=your_google_gemini_api_key_here

# Database Configuration (optional - defaults to SQLite if MySQL not available)
# DATABASE_URL=mysql+mysqlconnector://user:password@host:port/dbname
# Or for PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Database fallback settings
ALLOW_SQLITE_FALLBACK=true
SQLITE_FALLBACK_URL=sqlite:///./autovision_studio.db

# Database credentials (alternative to DATABASE_URL)
# DB_USER=root
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=autovision_studio

# Session Configuration
SESSION_SECRET=your-random-secret-key-change-this
SESSION_MAX_AGE=28800
SESSION_HTTPS_ONLY=false

# Application Settings
GENERATED_APPS_ROOT=generated_apps
IMAGE_CACHE_ROOT=generated_image_cache

# Password hashing
PASSWORD_HASH_ITERATIONS=390000
